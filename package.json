  },
  "scripts": {
    "biome:migrate": "biome migrate --write",
    "build": "vite build",
    "cf:deploy": "pnpm run build && wrangler deploy",
    "cf:typegen": "wrangler types src/worker-configuration.d.ts",
    "commit": "tsx ./node_modules/cz-customizable/standalone.js",
    "dev": "vite",
    "format": "biome check . --fix",
    "generate:registry": "tsx scripts/generateComponentRegistry.ts -w src/lib/registry/generated-registry-components.ts && tsx scripts/generateParticleRegistry.ts && pnpm format",
    "lint:audit": "pnpx knip --max-show-issues 20",
    "lint:check": "svelte-kit sync && pnpx svelte-check --workspace .",
    "lint:typecheck": "tsc --noEmit",
    "mrproper": "rm -rf node_modules dist build .svelte-kit",
    "optimize:icons": "tsx ./scripts/transformLucideImports.ts",
    "prepare": "husky && svelte-kit sync || echo ''"
  },
  "type": "module",
  "version": "0.9.3"
}
